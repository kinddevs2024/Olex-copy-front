{
  "project": {
    "name": "no-name",
    "type": "Premium car marketplace mobile app",
    "design_direction": "Minimal, luxury, black & white Apple-style interface",
    "feeling": "Premium, clean, calm, high-value, trustworthy"
  },
  "design_system": {
    "colors": {
      "primary": "#000000",
      "background": "#FFFFFF",
      "secondary_background": "#F5F5F7",
      "border": "#E5E5EA",
      "text_primary": "#000000",
      "text_secondary": "#8E8E93",
      "button_text": "#FFFFFF"
    },
    "color_rules": [
      "Only black, white, and light gray allowed",
      "No bright colors, no purple, no gradients",
      "Use contrast instead of color for hierarchy"
    ],
    "typography": {
      "style": "Luxury, modern, minimal, editorial",
      "font_direction": "High-end fashion + tech blend",
      "recommended_fonts": [
        "SF Pro Display (Apple style)",
        "Playfair Display (luxury serif)",
        "Inter (clean modern fallback)"
      ],
      "rules": [
        "Titles must feel strong and premium",
        "Prices must be bold and dominant",
        "Body text must be clean and readable",
        "Avoid playful or casual fonts"
      ],
      "hierarchy": {
        "hero_title": {
          "size": 28,
          "weight": "900",
          "letter_spacing": "-0.5"
        },
        "section_title": {
          "size": 22,
          "weight": "800"
        },
        "card_title": {
          "size": 16,
          "weight": "700"
        },
        "price": {
          "size": 18,
          "weight": "900"
        },
        "body": {
          "size": 14,
          "weight": "400"
        },
        "caption": {
          "size": 12,
          "weight": "400"
        }
      }
    },
    "layout": {
      "style": "Spacious and breathable",
      "padding": 18,
      "grid": "8pt system",
      "border_radius": {
        "cards": 22,
        "buttons": 18,
        "inputs": 18,
        "chips": 30
      }
    },
    "components": {
      "buttons": {
        "primary": {
          "background": "#000000",
          "text": "#FFFFFF",
          "feel": "Strong, confident, premium"
        },
        "secondary": {
          "background": "#FFFFFF",
          "border": "#E5E5EA",
          "text": "#000000"
        }
      },
      "cards": {
        "background": "#FFFFFF",
        "border": "1px solid #E5E5EA",
        "shadow": "None or extremely soft",
        "image_radius": 18
      },
      "inputs": {
        "background": "#F5F5F7",
        "border": "None",
        "text_color": "#000000",
        "placeholder": "#8E8E93"
      }
    }
  },
  "screens": [
    {
      "name": "Home",
      "goal": "Quick browsing and discovery",
      "elements": [
        "Brand name (no-name)",
        "Minimal search bar",
        "Category chips",
        "Hero premium section",
        "Car listing cards",
        "Bottom navigation"
      ],
      "hero_section": {
        "background": "#000000",
        "text": "#FFFFFF",
        "message": "Premium car marketplace"
      }
    },
    {
      "name": "Car Detail",
      "goal": "Provide full car information and drive contact",
      "elements": [
        "Large image gallery",
        "Big bold price",
        "Car title",
        "Specifications",
        "Seller info",
        "Contact buttons"
      ]
    },
    {
      "name": "Search / Filter",
      "goal": "Help user find exact car",
      "elements": [
        "Search input",
        "Brand",
        "Model",
        "Price range",
        "Year",
        "Mileage",
        "Fuel",
        "Transmission",
        "Location",
        "Apply button"
      ]
    },
    {
      "name": "Add Listing",
      "goal": "User posts car",
      "elements": [
        "Photo upload",
        "Car fields",
        "Description",
        "Price",
        "Phone number",
        "Submit button"
      ]
    },
    {
      "name": "Profile",
      "goal": "User account management",
      "elements": [
        "Avatar",
        "User name",
        "Phone",
        "My listings",
        "Favorites",
        "Messages",
        "Settings"
      ]
    }
  ],
  "navigation": {
    "type": "Bottom navigation",
    "style": "Minimal, icon + label",
    "tabs": [
      "Home",
      "Search",
      "Add",
      "Favorites",
      "Profile"
    ]
  },
  "user_flows": [
    {
      "name": "Browse and buy",
      "flow": [
        "Home",
        "Select car",
        "View details",
        "Contact seller"
      ]
    },
    {
      "name": "Search flow",
      "flow": [
        "Search",
        "Apply filters",
        "View results",
        "Select car"
      ]
    },
    {
      "name": "Sell car",
      "flow": [
        "Add listing",
        "Upload images",
        "Fill details",
        "Submit"
      ]
    }
  ],
  "design_principles": [
    "Minimal over complex",
    "Premium over playful",
    "Clarity over decoration",
    "Spacing over clutter",
    "Black & white over colorful UI",
    "Trust and value must be visible instantly"
  ],
  "notes_for_team": [
    "Do NOT use OLX colors or branding",
    "Do NOT use purple anywhere",
    "Keep UI calm and premium",
    "Cars must feel expensive visually",
    "Typography is critical for luxury feel"
  ]
}
